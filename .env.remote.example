# EcoSeek — Remote-only thin client configuration
#
# Copy this file to .env and fill in your remote AgenticPlug broker URL.
# Then run:  docker compose --profile remote up
#
# Or skip Docker entirely and use ecoseek-client directly:
#   pip install -e ../ecoseek-client
#   ecoseek login --broker https://your-agenticplug-url
#   ecoseek hermes orchestrate "List mammal species in Yucatan"

# ── Required: Remote AgenticPlug broker URL ──────────────────────────
# This is the only required field. Point it to the AgenticPlug broker
# running on reumanlab (or wherever the gateway is deployed).
AGENTICPLUG_URL=https://your-agenticplug-broker-url

# ── Hermes orchestration (enabled by default in remote mode) ─────────
HERMES_ENABLED=true
# HERMES_URL and HERMES_API_KEY are configured on the broker side,
# not needed here — the broker forwards /v1/orchestrate to Hermes.

# ── EcoSeek API port (default: 3000) ─────────────────────────────────
ECOSEEK_API_PORT=3000

# ── Optional: Local LLM fallback ─────────────────────────────────────
# If you have a local Ollama or similar running outside Docker:
# LOCAL_LLM_URL=http://host.docker.internal:11434

# ── Optional: Phoenix observability ──────────────────────────────────
# PHOENIX_ENABLED=true
# PHOENIX_ENDPOINT=http://your-phoenix-host:6006/v1/traces

# ── Upstream timeout (seconds) ───────────────────────────────────────
UPSTREAM_TIMEOUT_S=120
